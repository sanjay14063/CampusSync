rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.uid in ['kuH8pdyMpBXDsJ60jH1p9GbW4uf1'];
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /user/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.role == 'student';
      allow update, delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if signedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        signedIn()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['currentParticipants', 'status'])
        && request.resource.data.currentParticipants is int
        && request.resource.data.currentParticipants >= 0
        && request.resource.data.currentParticipants <= resource.data.maxCapacity
        && (
          request.resource.data.currentParticipants == resource.data.currentParticipants + 1
          || request.resource.data.currentParticipants == resource.data.currentParticipants - 1
        )
        && request.resource.data.status in ['Active', 'Full', 'Completed']
      );
    }

    match /registrations/{registrationId} {
      allow read: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.eventId is string
        && registrationId == request.resource.data.eventId + '_' + request.auth.uid
        && get(/databases/$(database)/documents/events/$(request.resource.data.eventId)).data.status == 'Active'
        && get(/databases/$(database)/documents/events/$(request.resource.data.eventId)).data.currentParticipants
          < get(/databases/$(database)/documents/events/$(request.resource.data.eventId)).data.maxCapacity;
      allow delete: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
      allow update: if false;
    }
  }
}
